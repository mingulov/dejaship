# DejaShip environment variables
# Copy to .env and fill in required values before running.
# All variables are prefixed with DEJASHIP_ (handled by pydantic-settings).

# ─── REQUIRED ────────────────────────────────────────────────────────────────

# Cloudflare Tunnel token — create at dash.cloudflare.com/tunnels
# Required for the tunnel service to expose api.dejaship.com
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token-here

# ─── DATABASE (optional — defaults work with docker-compose) ─────────────────

# DEJASHIP_DATABASE_URL=postgresql+asyncpg://dejaship:dejaship@db:5432/dejaship

# ─── CORS ────────────────────────────────────────────────────────────────────

# DEJASHIP_CORS_ORIGINS=https://dejaship.com

# ─── RATE LIMITS (requests per minute per IP) ────────────────────────────────

# DEJASHIP_RATE_LIMIT_CHECK=60/minute
# DEJASHIP_RATE_LIMIT_CLAIM=60/minute
# DEJASHIP_RATE_LIMIT_UPDATE=60/minute
# DEJASHIP_RATE_LIMIT_MCP=60/minute
# DEJASHIP_RATE_LIMIT_STATS=120/minute

# ─── SEARCH QUALITY (experiment flags — all disabled by default) ──────────────
# See docs/search-quality/improvement-approaches.md before enabling.

# DEJASHIP_ENABLE_JACCARD_FILTER=false
# DEJASHIP_JACCARD_THRESHOLD=0.15

# DEJASHIP_ENABLE_KEYWORD_CLEANUP=false
# DEJASHIP_ENABLE_NLTK_STOPWORDS=false
# DEJASHIP_ENABLE_SPACY_LEMMATIZATION=false

# DEJASHIP_ENABLE_TWO_STAGE_RETRIEVAL=false
# DEJASHIP_ENABLE_RERANKER=false
# DEJASHIP_ENABLE_HYBRID_SEARCH=false

# ─── STALE CLAIM CLEANUP ─────────────────────────────────────────────────────
# Claims not updated in N days are auto-abandoned by scripts/abandon_stale.py

# DEJASHIP_ABANDONMENT_DAYS=7
